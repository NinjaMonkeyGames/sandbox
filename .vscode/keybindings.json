////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
//                                                   IDE KEYBINDINGS                                                  //
////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

// 1. Convert Selected Text To Title Case.

{
    // Convert Selected Text to Title Case

    "key": "ctrl+shift+t",                              // Bind to CTRL + SHIFT + T
    "command": "editor.action.transformToTitlecase",    // Transform text to title case
    "when": "editorTextFocus"                           // Transform selected text only
}