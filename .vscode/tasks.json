{
    "version": "2.0.0", // tasks.json parser version
    "tasks":            // Initialise tasks    
    [
        {
            // Initialisation

            "label": "Install dependencies", // Set install dependencies label
            "type": "shell",                 // Set script type to shell
            "command": "powershell",         // Run shell command in Powershell
            "args":                          // Shell code to run setup if it hasn't already
            
            // Check if 'node_modules' folder is present in project. If not it will build it from 'package.json'.

            [
                "-Command",
                "if (-Not (Test-Path 'node_modules')) { Write-Host 'Installing dependencies, please wait...'; npm install; Write-Host 'npm install completed.' } else { Write-Host 'node_modules already exists. Skipping npm install.' }"
            ],

            "group": 
            {
                "kind": "build",
                "isDefault": true
            },
        }
    ]
} 
